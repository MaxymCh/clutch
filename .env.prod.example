# =========================================================================
# Production BACKEND Clutch — copier en ".env" sur le VPS puis remplir.
#   cp .env.prod.example .env
# Ne JAMAIS commiter ce fichier .env (voir .gitignore racine).
# (Le front a son propre env côté Cloudflare Pages, cf. roadmap.)
# =========================================================================

# --- PostgreSQL (conteneur db, self-hosted sur le VPS) ---------------------
POSTGRES_USER=clutch
POSTGRES_PASSWORD=CHANGE_ME_mot_de_passe_fort
POSTGRES_DB=clutch
# DATABASE_URL est dérivé automatiquement dans docker-compose.prod.yml.

# --- Supabase (auth uniquement — vérif des JWT côté API) -------------------
# Dashboard Supabase → Settings → API.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Settings → API → JWT Secret (sert de fallback HS256 ; ES256 via JWKS).
SUPABASE_JWT_SECRET=CHANGE_ME_jwt_secret_supabase

# --- Liquipedia (worker d'ingestion uniquement) ----------------------------
LIQUIPEDIA_API_KEY=ta_cle_lpdb_v3
LIQUIPEDIA_USER_AGENT=Clutch/1.0 (projet etudiant ETNA; contact: maxym0308@gmail.com)
# Tournois EWC 2026 : {gameId: pagename Liquipedia}. Vérifier les pagenames réels.
EWC_TOURNAMENTS={"val": "Esports_World_Cup/2026", "lol": "Esports_World_Cup/2026", "cs2": "Esports_World_Cup/2026"}
INGEST_INTERVAL_MINUTES=15

# --- API -------------------------------------------------------------------
DISPLAY_TZ=Europe/Paris
# Origine(s) PUBLIQUE(S) du front (Cloudflare Pages) autorisées en CORS.
# Ajouter ici toute origine web ; l'app mobile native n'est pas concernée.
CORS_ORIGINS=["https://clutch-esports.eu", "https://www.clutch-esports.eu"]
SCORING_INTERVAL_SECONDS=60

# --- Tunnel (VPS sans IP publique) -----------------------------------------
# Token du tunnel Cloudflare (Zero Trust → Tunnels). Laisser vide si tu
# utilises Tailscale Funnel à la place.
CLOUDFLARE_TUNNEL_TOKEN=
