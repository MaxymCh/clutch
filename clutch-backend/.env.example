# --- Base de données -------------------------------------------------------
# En local hors Docker : localhost:5433 (Docker mappe 5433→5432 ; 5432 est souvent
# pris par un Postgres Windows). Dans docker-compose le host devient "db".
DATABASE_URL=postgresql+psycopg://clutch:clutch@localhost:5433/clutch

# --- Liquipedia (ingestion uniquement, jamais côté API) --------------------
# Clé API LPDB v3 — https://liquipedia.net/api-terms-of-use
LIQUIPEDIA_API_KEY=changeme
# User-Agent DESCRIPTIF avec contact (les UA génériques sont bloqués).
LIQUIPEDIA_USER_AGENT=Clutch/0.1 (projet etudiant ETNA; contact: maxym0308@gmail.com)

# Tournois EWC 2026 à ingérer : JSON {gameId: pagename Liquipedia}.
# Ajouter/retirer un jeu = éditer cette variable, AUCUN changement de code.
# gameIds valides : val, lol, cs2, dota, rl, r6, ow (contrat front).
# Scoreboards joueurs via LPDB : val (agents/ACS/ADR), lol (champions/poste),
# dota (héros/GPM/net worth/CS). cs2/rl/r6 : matchs + scores sans stats joueur.
# ⚠️ Valeurs ci-dessous = EXEMPLES de forme — vérifier les pagenames réels
# des pages EWC 2026 sur chaque wiki avant la première ingestion.
EWC_TOURNAMENTS={"val": "Esports_World_Cup/2026", "lol": "Esports_World_Cup/2026", "cs2": "Esports_World_Cup/2026", "dota": "Esports_World_Cup/2026", "rl": "Esports_World_Cup/2026", "r6": "Esports_World_Cup/2026"}

# Intervalle du worker d'ingestion (minutes). Rate limit LPDB : 60 req/h.
INGEST_INTERVAL_MINUTES=15

# --- API --------------------------------------------------------------------
# Fuseau de SORTIE des champs date/time des matchs (stockage interne en UTC).
DISPLAY_TZ=Europe/Paris
# Origines autorisées (CORS) — l'URL du front, jamais "*".
CORS_ORIGINS=["http://localhost:5173"]
# Secret JWT Supabase : dashboard Supabase → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=changeme
# URL + clé anon Supabase (utilisées par POST /auth/token pour tester depuis Swagger).
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Intervalle de la tâche de scoring côté API (secondes).
SCORING_INTERVAL_SECONDS=60
