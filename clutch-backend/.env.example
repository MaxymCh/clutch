# --- Base de données -------------------------------------------------------
# En local hors Docker : localhost ; dans docker-compose le host devient "db".
DATABASE_URL=postgresql+psycopg://clutch:clutch@localhost:5432/clutch

# --- Liquipedia (ingestion uniquement, jamais côté API) --------------------
# Clé API LPDB v3 — https://liquipedia.net/api-terms-of-use
LIQUIPEDIA_API_KEY=changeme
# User-Agent DESCRIPTIF avec contact (les UA génériques sont bloqués).
LIQUIPEDIA_USER_AGENT=Clutch/0.1 (projet etudiant ETNA; contact: maxym0308@gmail.com)

# Tournois EWC 2026 à ingérer : JSON {gameId: pagename Liquipedia}.
# Ajouter/retirer un jeu = éditer cette variable, AUCUN changement de code.
# gameIds valides : val, lol, cs2, dota, rl, ow (contrat front).
# ⚠️ Valeurs ci-dessous = EXEMPLES de forme — vérifier les pagenames réels
# des pages EWC 2026 sur chaque wiki avant la première ingestion.
EWC_TOURNAMENTS={"val": "Esports_World_Cup/2026", "lol": "Esports_World_Cup/2026", "cs2": "Esports_World_Cup/2026"}

# Intervalle du worker d'ingestion (minutes). Rate limit LPDB : 60 req/h.
INGEST_INTERVAL_MINUTES=15

# --- API --------------------------------------------------------------------
# Fuseau de SORTIE des champs date/time des matchs (stockage interne en UTC).
DISPLAY_TZ=Europe/Paris
# Origines autorisées (CORS) — l'URL du front, jamais "*".
CORS_ORIGINS=["http://localhost:5173"]
# Secret de signature du cookie de session anonyme (générer une valeur forte).
SESSION_SECRET=changeme-generate-a-long-random-string
# true en prod (HTTPS requis pour SameSite=None) ; false en dev local.
COOKIE_SECURE=false
# Intervalle de la tâche de scoring côté API (secondes).
SCORING_INTERVAL_SECONDS=60
