                }
              ]
            },
            "description": "Tournoi avec de vraies dates — utile pour tester l'ingestion."
          },
          "response": []
        },
        {
          "name": "EWC 2026 — squelette (placeholders)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Apikey {{LIQUIPEDIA_API_KEY}}",
                "type": "text"
              },
              {
                "key": "User-Agent",
                "value": "{{LIQUIPEDIA_USER_AGENT}} (via Postman)",
                "type": "text"
              },
              {
                "key": "Accept-Encoding",
                "value": "gzip",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/match?wiki=valorant&conditions=[[parent::Esports_World_Cup/2026]] OR [[pagename::Esports_World_Cup/2026]]&query=match2id,date,match2opponents&limit=5&order=date ASC",
              "host": ["{{baseUrl}}"],
              "path": ["match"],
              "query": [
                {
                  "key": "wiki",
                  "value": "valorant"
                },
                {
                  "key": "conditions",
                  "value": "[[parent::Esports_World_Cup/2026]] OR [[pagename::Esports_World_Cup/2026]]"
                },
                {
                  "key": "query",
                  "value": "match2id,date,match2opponents"
                },
                {
                  "key": "limit",
                  "value": "5"
                },
                {
                  "key": "order",
                  "value": "date ASC"
                }
              ]
            },
            "description": "Montre pourquoi le worker ignore les matchs : `date=0000-01-01`, équipes vides."
          },
          "response": []
        }
      ]
    }
  ]
}
